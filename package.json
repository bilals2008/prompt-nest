{
  "name": "prompt-nest",
  "productName": "Prompt Nest",
  "description": "A prompt management and organization tool",
  "author": "Bilal S.",
  "private": true,
  "version": "0.0.7-beta",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && electron-builder",
    "dist:win": "vite build && electron-builder --win nsis",
    "dist:win:publish": "vite build && electron-builder --win nsis --publish always",
    "release": "node scripts/release-full.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "postinstall": "electron-builder install-app-deps",
    "rebuild": "electron-builder install-app-deps"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "react-markdown": "^10.1.0",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "@base-ui/react": "^1.5.0",
    "@eslint/js": "^9.27.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@tabler/icons-react": "^3.44.0",
    "@tailwindcss/vite": "^4.3.0",
    "@vitejs/plugin-react": "^6.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.2.1",
    "electron": "^42.2.0",
    "@electron/asar": "^3.2.0",
    "electron-builder": "^26.8.1",
    "embla-carousel-react": "^8.6.0",
    "eslint": "^10.4.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.16.0",
    "node-abi": "^4.31.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.6",
    "react-resizable-panels": "^4.11.1",
    "react-router-dom": "^7.15.1",
    "recharts": "^3.8.1",
    "shadcn": "^4.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "vite": "^8.0.14",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.7"
  },
  "main": "dist-electron/main.js",
  "build": {
    "appId": "com.promptnest.app",
    "productName": "Prompt Nest",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "dist-electron/main.js"
    },
    "win": {
      "icon": "build/icon.png",
      "artifactName": "Prompt-Nest-Setup-${version}.${ext}",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "differentialPackage": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "bilals2008",
        "repo": "prompt-nest"
      }
    ],
    "generateUpdatesFilesForAllChannels": true
  }
}
